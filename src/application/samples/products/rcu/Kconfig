choice
    prompt "Support server or client."
    default SAMPLE_SUPPORT_RCU_SERVER
    depends on SAMPLE_SUPPORT_RCU
    config SAMPLE_SUPPORT_RCU_SERVER
        bool "Support server."
    config SAMPLE_SUPPORT_RCU_CLIENT
        bool "Support client."
endchoice

config SAMPLE_SUPPORT_SLE_RCU_SERVER
    bool
    prompt "Enable SLE RCU Server sample."
    default n
    depends on SAMPLE_SUPPORT_RCU_SERVER
    help
        This option means the SLE type of rcu to select.

config SAMPLE_SUPPORT_BLE_RCU_SERVER
    bool
    prompt "Enable BLE RCU Server sample."
    default n
    depends on SAMPLE_SUPPORT_RCU_SERVER
    help
        This option means the BLE type of rcu to select.

choice
    prompt "Support sle or ble Client."
    default SAMPLE_SUPPORT_SLE_CLIENT
    depends on SAMPLE_SUPPORT_RCU_CLIENT
    config SAMPLE_SUPPORT_SLE_CLIENT
        bool "Support sle Client."
    config SAMPLE_SUPPORT_BLE_CLIENT
        bool "Support ble Client."
endchoice

choice
    prompt "select first or second Client."
    default SAMPLE_SUPPORT_CLIENT_TV
    depends on SAMPLE_SUPPORT_RCU_CLIENT
    config SAMPLE_SUPPORT_CLIENT_TV
        bool "TV Client."
    config SAMPLE_SUPPORT_CLIENT_OTT
        bool "OTT Client."
endchoice

config RCU_MTU_LENGTH
    int
    prompt "Set the length of mtu."
    depends on SAMPLE_SUPPORT_RCU_CLIENT
    default 300
    help
        This option means the length of mtu.

config RCU_MULTICON_NUM
    int
    prompt "Set the num of rcu multicon."
    range 1 2
    default 1
    help
        This option means the num of rcu multicon.

config SAMPLE_SUPPORT_IR
    bool
    select DRIVER_SUPPORT_IR
    select PWM_PRELOAD
    prompt "Select IR rcu type."
    default n
    help
        This option means the IR type of rcu to select.

