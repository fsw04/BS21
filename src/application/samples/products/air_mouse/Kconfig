config AIR_MOUSE_UART_TX_PIN
    int
    range 26 26 if AIR_MOUSE_HR_BOARD
    range 26 26 if AIR_MOUSE_HX_BOARD
    range 30 30 if AIR_MOUSE_SELF_BOARD
    range 30 30 if AIR_MOUSE_EVB4_BOARD
    range 30 30 if AIR_MOUSE_RADAR_2T4R_BOARD
    range 26 26 if AIR_MOUSE_OPEN_SOURCE_BOARD
    prompt "Set the uart tx pin num."
config AIR_MOUSE_UART_RX_PIN
    int
    range 27 27 if AIR_MOUSE_HR_BOARD
    range 27 27 if AIR_MOUSE_HX_BOARD
    range 31 31 if AIR_MOUSE_SELF_BOARD
    range 31 31 if AIR_MOUSE_EVB4_BOARD
    range 31 31 if AIR_MOUSE_RADAR_2T4R_BOARD
    range 27 27 if AIR_MOUSE_OPEN_SOURCE_BOARD
    prompt "Set the uart rx pin num."
config AIR_MOUSE_UART_CTS_PIN
    int
    range 28 28 if AIR_MOUSE_HR_BOARD
    range 28 28 if AIR_MOUSE_HX_BOARD
    range 3 3 if AIR_MOUSE_SELF_BOARD
    range 3 3 if AIR_MOUSE_EVB4_BOARD
    range 3 3 if AIR_MOUSE_RADAR_2T4R_BOARD
    range 28 28 if AIR_MOUSE_OPEN_SOURCE_BOARD
    prompt "Set the uart cts pin num."
config AIR_MOUSE_UART_RTS_PIN
    int
    range 29 29 if AIR_MOUSE_HR_BOARD
    range 29 29 if AIR_MOUSE_HX_BOARD
    range 4 4 if AIR_MOUSE_SELF_BOARD
    range 4 4 if AIR_MOUSE_EVB4_BOARD
    range 4 4 if AIR_MOUSE_RADAR_2T4R_BOARD
    range 29 29 if AIR_MOUSE_OPEN_SOURCE_BOARD
    prompt "Set the uart rts pin num."
config AIR_MOUSE_POWER_ON_PIN
    int
    range 12 12 if AIR_MOUSE_HR_BOARD
    range 12 12 if AIR_MOUSE_HX_BOARD
    range 26 26 if AIR_MOUSE_SELF_BOARD
    range 26 26 if AIR_MOUSE_EVB4_BOARD
    range 26 26 if AIR_MOUSE_RADAR_2T4R_BOARD
    range 12 12 if AIR_MOUSE_OPEN_SOURCE_BOARD
    prompt "Set the slp power on pin num."
config AIR_MOUSE_POWER_CTRL_PIN
    int
    range 13 13 if AIR_MOUSE_HR_BOARD
    range 13 13 if AIR_MOUSE_HX_BOARD
    range 32 32 if AIR_MOUSE_SELF_BOARD
    range 2 2 if AIR_MOUSE_EVB4_BOARD
    range 2 2 if AIR_MOUSE_RADAR_2T4R_BOARD
    range 13 13 if AIR_MOUSE_OPEN_SOURCE_BOARD
    prompt "Set the slp power ctrl pin num."
config AIR_MOUSE_DEV_WAKEUP_HOST_PIN
    int
    range 15 15 if AIR_MOUSE_HR_BOARD
    range 15 15 if AIR_MOUSE_HX_BOARD
    range 29 29 if AIR_MOUSE_SELF_BOARD
    range 29 29 if AIR_MOUSE_EVB4_BOARD
    range 29 29 if AIR_MOUSE_RADAR_2T4R_BOARD
    range 6 6 if AIR_MOUSE_OPEN_SOURCE_BOARD
    prompt "Set the dev wakeup host pin num."
config AIR_MOUSE_SYNC_PIN
    int
    range 10 10 if AIR_MOUSE_HR_BOARD
    range 10 10 if AIR_MOUSE_HX_BOARD
    range 5 5 if AIR_MOUSE_SELF_BOARD
    range 5 5 if AIR_MOUSE_EVB4_BOARD
    range 5 5 if AIR_MOUSE_RADAR_2T4R_BOARD
    range 10 10 if AIR_MOUSE_OPEN_SOURCE_BOARD
    prompt "Set the sync pin num."
config AIR_MOUSE_IMU_INT2_PIN
    int
    range 14 14 if AIR_MOUSE_HR_BOARD
    range 14 14 if AIR_MOUSE_HX_BOARD
    range 32 32 if AIR_MOUSE_SELF_BOARD
    range 28 28 if AIR_MOUSE_EVB4_BOARD
    range 28 28 if AIR_MOUSE_RADAR_2T4R_BOARD
    range 14 14 if AIR_MOUSE_OPEN_SOURCE_BOARD
    prompt "Set the imu int2 pin num."
config ADC_USE_PIN1
    int
    prompt "Choose ADC USE pin1."
    default 30
    depends on SAMPLE_SUPPORT_AIR_MOUSE

config ADC_USE_PIN2
    int
    prompt "Choose ADC USE pin2."
    default 31
    depends on SAMPLE_SUPPORT_AIR_MOUSE

config USB_UAC_MAX_RECORD_SIZE
    hex
    prompt "Set the max recorder size of USB UAC."
    default 0x400
    help
        This option means the max recorder size of USB UAC.
    depends on SAMPLE_SUPPORT_AIR_MOUSE

config USB_PDM_TRANSFER_LEN_BY_DMA
    int
    prompt "Set the length of transfer by DMA."
    default 256
    help
        This option means the length of transfer by DMA.
    depends on SAMPLE_SUPPORT_AIR_MOUSE
