config SLE_1VN_SERVER_MAC_ADDR
    hex
    default 0x787060889647
    prompt "Set the BS21E SLE 1VN server MAC address."
    depends on ENABLE_SLE_1VN
    help
        This option means the MAC address of the SLE 1VN server.

config SLE_1VN_SERVER_ID
    int
    range 0 99
    default 1
    prompt "Set the watch ID of SLE 1VN server."
    depends on ENABLE_SLE_1VN
    help
        This option means the numeric ID appended to the advertised SLE name.
        The client can scan this server by the complete local name watch-xx.

config SLE_1VN_SERVER_NAME_PREFIX
    string
    prompt "Set the advertised name prefix of SLE 1VN server."
    default "watch"
    depends on ENABLE_SLE_1VN
    help
        This option means the prefix of the SLE 1VN server name.
        The final advertised name is prefix-ID, such as watch-01.

