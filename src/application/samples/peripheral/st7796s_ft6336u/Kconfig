#===============================================================================
# @brief    ST7796S LCD + FT6336U touch + SLE 1VN health monitor configuration
#===============================================================================

#-------------------------------------------------------------------------------
# LCD 配置
#-------------------------------------------------------------------------------
config ST7796S_LCD_BL_ENABLE
    bool
    prompt "Drive ST7796S LCD backlight GPIO high."
    depends on SAMPLE_SUPPORT_ST7796S_FT6336U
    default y

config ST7796S_MADCTL
    hex
    prompt "ST7796S MADCTL value."
    depends on SAMPLE_SUPPORT_ST7796S_FT6336U
    default 0x28

#-------------------------------------------------------------------------------
# 触控配置
#-------------------------------------------------------------------------------
config FT6336U_USE_INT_PIN
    bool
    prompt "Configure FT6336U INT pin as input."
    depends on SAMPLE_SUPPORT_ST7796S_FT6336U
    default n

#-------------------------------------------------------------------------------
# SLE 1VN 服务端配置
#-------------------------------------------------------------------------------
config ST7796S_SLE_1VN_ENABLE
    bool
    prompt "Enable SLE 1VN server functionality."
    depends on SAMPLE_SUPPORT_ST7796S_FT6336U
    default y

config SLE_1VN_SERVER_MAC_ADDR
    hex
    default 0x787060889647
    prompt "Set the SLE 1VN server MAC address."
    depends on ST7796S_SLE_1VN_ENABLE

config SLE_1VN_SERVER_ID
    int
    range 0 99
    default 1
    prompt "Set the watch ID of SLE 1VN server."
    depends on ST7796S_SLE_1VN_ENABLE

config SLE_1VN_SERVER_NAME_PREFIX
    string
    prompt "Set the advertised name prefix of SLE 1VN server."
    default "watch"
    depends on ST7796S_SLE_1VN_ENABLE

#-------------------------------------------------------------------------------
# 字体配置
#-------------------------------------------------------------------------------
config FONT_HZK16_ENABLE
    bool
    prompt "Enable HZK16 Chinese font support (requires ~260KB flash)."
    depends on SAMPLE_SUPPORT_ST7796S_FT6336U
    default n
    help
        Enable this to include the HZK16 16x16 Chinese font data.
        When disabled, Chinese characters are rendered as placeholder blocks.
        The HZK16 binary file must be provided separately and linked
        via CMake objcopy or included as a C array.
